# ============================
# Unreal Engine Git Ignore
# Works for UE 5.4 / 5.x / 4.x
# C++ Projects
# ============================

# Ignore build artifacts
Binaries/
DerivedDataCache/
Intermediate/
Saved/

# Ignore VS + Rider + CLion IDE files
.vscode/
.vs/
.idea/

# Ignore project user files
*.suo
*.user
*.userprefs
*.sln.docstates
*.opensdf
*.sdf
*.VC.db
*.VC.opendb

# Ignore generated project files
*.xcodeproj
*.xcworkspace
*.xcconfig
*.DS_Store

# Ignore compiled shader caches
*.pch
*.pdb
*.idb

# Ignore plugin intermediates
Plugins/*/Intermediate/
Plugins/*/Binaries/

# Ignore backup files
*_Backup/*
Backup/
*.bak

# Ignore the Derived Data Cache (local machine only)
DerivedDataCache/

# Ignore config cache
Config/*.ini.local
Config/DefaultEditorPerProjectUserSettings.ini

# Ignore Crash Reports
Saved/Crashes/

# Ignore Maps auto-saves
Saved/Autosaves/

# Ignore logs
Saved/Logs/

# Ignore temporary files
*.obj
*.mod
*.tlog
*.log
*.cache
*.tmp

# Ignore generated files from UHT (Unreal Header Tool)
*.generated.h
*.generated.cpp

# Ignore Build data (but keep Source, Config, Content)
Build/

# Ignore autogenerated Android/IOS files
Intermediate/Android/
Intermediate/IOS/
Saved/StagedBuilds/

# Git LFS recommended for large files
# (Optional but highly recommended)
# *.uasset filter=lfs diff=lfs merge=lfs -text
# *.umap filter=lfs diff=lfs merge=lfs -text

# END
